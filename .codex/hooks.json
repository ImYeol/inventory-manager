{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "handlers": [
          {
            "type": "command",
            "command": "zsh .codex/hooks/dangerous-cmd-guard.sh",
            "timeoutSec": 5
          },
          {
            "type": "command",
            "command": "zsh .codex/hooks/ui-review-guard.sh",
            "timeoutSec": 5
          },
          {
            "type": "command",
            "command": "zsh .codex/hooks/tdd-guard.sh",
            "timeoutSec": 5
          }
        ]
      }
    ]
  }
}
