{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "handlers": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/session_start.py",
            "timeoutSec": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "handlers": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/user_prompt_submit.py",
            "timeoutSec": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "handlers": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/pre_tool_use.py",
            "timeoutSec": 5
          }
        ]
      }
    ]
  }
}
