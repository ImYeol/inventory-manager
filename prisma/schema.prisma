generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TransactionTypeValue {
  INBOUND
  OUTBOUND
  ADJUSTMENT

  @@map("transaction_type_value")
}

model AppUser {
  id        String   @id @db.Uuid
  email     String?  @unique
  fullName  String?  @map("full_name")
  role      String   @default("manager")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("app_users")
}

model Model {
  id           BigInt        @id @default(autoincrement()) @db.BigInt
  userId       String        @map("user_id") @db.Uuid
  name         String
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  sizes        Size[]
  colors       Color[]
  inventory    Inventory[]
  transactions Transaction[]

  @@unique([id, userId])
  @@unique([userId, name])
  @@index([userId, createdAt(sort: Desc)], map: "models_user_id_created_at_idx")
  @@map("models")
}

model Size {
  id           BigInt        @id @default(autoincrement()) @db.BigInt
  userId       String        @map("user_id") @db.Uuid
  modelId      BigInt        @map("model_id") @db.BigInt
  name         String
  sortOrder    Int           @default(0) @map("sort_order")
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  model        Model         @relation(fields: [modelId, userId], references: [id, userId], onDelete: Cascade)
  inventory    Inventory[]
  transactions Transaction[]

  @@unique([modelId, id, userId])
  @@unique([userId, modelId, name])
  @@index([modelId, userId], map: "sizes_model_id_user_id_idx")
  @@index([userId, sortOrder, modelId, name], map: "sizes_user_id_sort_order_model_id_name_idx")
  @@map("sizes")
}

model Color {
  id           BigInt        @id @default(autoincrement()) @db.BigInt
  userId       String        @map("user_id") @db.Uuid
  modelId      BigInt        @map("model_id") @db.BigInt
  name         String
  rgbCode      String        @map("rgb_code")
  textWhite    Boolean       @default(false) @map("text_white")
  sortOrder    Int           @default(0) @map("sort_order")
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  model        Model         @relation(fields: [modelId, userId], references: [id, userId], onDelete: Cascade)
  inventory    Inventory[]
  transactions Transaction[]

  @@unique([modelId, id, userId])
  @@unique([userId, modelId, name])
  @@index([modelId, userId], map: "colors_model_id_user_id_idx")
  @@index([userId, sortOrder, modelId, name], map: "colors_user_id_sort_order_model_id_name_idx")
  @@map("colors")
}

model Warehouse {
  id        BigInt        @id @default(autoincrement()) @db.BigInt
  userId    String        @map("user_id") @db.Uuid
  name      String
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  inventory Inventory[]
  Transaction Transaction[]

  @@unique([id, userId])
  @@unique([userId, name])
  @@index([userId, createdAt(sort: Desc)], map: "warehouses_user_id_created_at_idx")
  @@map("warehouses")
}

model Inventory {
  id        BigInt         @id @default(autoincrement()) @db.BigInt
  userId    String         @map("user_id") @db.Uuid
  modelId   BigInt         @map("model_id") @db.BigInt
  sizeId    BigInt         @map("size_id") @db.BigInt
  colorId   BigInt         @map("color_id") @db.BigInt
  warehouseId BigInt       @map("warehouse_id") @db.BigInt
  quantity  Int            @default(0)
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)
  model     Model          @relation(fields: [modelId, userId], references: [id, userId], onDelete: Cascade)
  size      Size           @relation(fields: [modelId, sizeId, userId], references: [modelId, id, userId], onDelete: Cascade)
  color     Color          @relation(fields: [modelId, colorId, userId], references: [modelId, id, userId], onDelete: Cascade)
  warehouse Warehouse      @relation(fields: [warehouseId, userId], references: [id, userId], onDelete: Cascade)

  @@unique([userId, modelId, sizeId, colorId, warehouseId])
  @@index([modelId, userId], map: "inventory_model_id_user_id_idx")
  @@index([modelId, sizeId, userId], map: "inventory_model_id_size_id_user_id_idx")
  @@index([modelId, colorId, userId], map: "inventory_model_id_color_id_user_id_idx")
  @@map("inventory")
}

model Transaction {
  id        BigInt               @id @default(autoincrement()) @db.BigInt
  userId    String               @map("user_id") @db.Uuid
  date      DateTime             @db.Date
  modelId   BigInt               @map("model_id") @db.BigInt
  sizeId    BigInt               @map("size_id") @db.BigInt
  colorId   BigInt               @map("color_id") @db.BigInt
  type      TransactionTypeValue
  quantity  Int
  warehouseId BigInt             @map("warehouse_id") @db.BigInt
  createdAt DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  model     Model                @relation(fields: [modelId, userId], references: [id, userId], onDelete: Cascade)
  size      Size                 @relation(fields: [modelId, sizeId, userId], references: [modelId, id, userId], onDelete: Cascade)
  color     Color                @relation(fields: [modelId, colorId, userId], references: [modelId, id, userId], onDelete: Cascade)
  warehouse Warehouse            @relation(fields: [warehouseId, userId], references: [id, userId], onDelete: Cascade)

  @@index([userId, date(sort: Desc), createdAt(sort: Desc)], map: "transactions_user_date_created_at_idx")
  @@index([modelId, userId], map: "transactions_model_id_user_id_idx")
  @@index([modelId, sizeId, userId], map: "transactions_model_id_size_id_user_id_idx")
  @@index([modelId, colorId, userId], map: "transactions_model_id_color_id_user_id_idx")
  @@map("transactions")
}

model ShippingProviderCredential {
  id               BigInt   @id @default(autoincrement()) @db.BigInt
  userId           String   @map("user_id") @db.Uuid
  provider         String
  encryptedPayload String   @map("encrypted_payload")
  iv               String
  authTag          String   @map("auth_tag")
  keyVersion       Int      @default(1) @map("key_version") @db.SmallInt
  maskedSummary    Json     @default("{}") @map("masked_summary")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([userId, provider])
  @@map("shipping_provider_credentials")
}
