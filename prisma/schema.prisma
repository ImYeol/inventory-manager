generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Warehouse {
  OGEUMDONG
  DAEJADONG
}

enum TransactionType {
  INBOUND
  OUTBOUND
  ADJUSTMENT
}

model Model {
  id            Int       @id @default(autoincrement())
  name          String    @unique
  createdAt     DateTime  @default(now())

  sizes         Size[]
  colors        Color[]
  inventory     Inventory[]
  transactions  Transaction[]
}

model Size {
  id        Int    @id @default(autoincrement())
  name      String
  sortOrder Int    @default(0)
  modelId   Int
  model     Model  @relation(fields: [modelId], references: [id], onDelete: Cascade)

  inventory    Inventory[]
  transactions Transaction[]

  @@unique([modelId, name])
}

model Color {
  id        Int     @id @default(autoincrement())
  name      String
  rgbCode   String  @default("#888888")
  textWhite Boolean @default(false)
  sortOrder Int     @default(0)
  modelId   Int
  model     Model   @relation(fields: [modelId], references: [id], onDelete: Cascade)

  inventory    Inventory[]
  transactions Transaction[]

  @@unique([modelId, name])
}

model Inventory {
  id        Int    @id @default(autoincrement())
  modelId   Int
  sizeId    Int
  colorId   Int
  warehouse Warehouse
  quantity  Int    @default(0)

  model Model @relation(fields: [modelId], references: [id], onDelete: Cascade)
  size  Size  @relation(fields: [sizeId], references: [id], onDelete: Cascade)
  color Color @relation(fields: [colorId], references: [id], onDelete: Cascade)

  @@unique([modelId, sizeId, colorId, warehouse])
  @@index([warehouse])
  @@index([modelId, warehouse])
}

model Transaction {
  id        Int             @id @default(autoincrement())
  date      DateTime        @db.Date
  modelId   Int
  sizeId    Int
  colorId   Int
  type      TransactionType
  quantity  Int
  warehouse Warehouse
  createdAt DateTime        @default(now())
  actorId   String?

  model Model @relation(fields: [modelId], references: [id], onDelete: Cascade)
  size  Size  @relation(fields: [sizeId], references: [id], onDelete: Cascade)
  color Color @relation(fields: [colorId], references: [id], onDelete: Cascade)

  @@index([date, createdAt(sort: Desc)])
  @@index([modelId, date])
  @@index([warehouse, date])
  @@index([type, date])
}
