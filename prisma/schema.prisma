generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TransactionTypeValue {
  INBOUND
  OUTBOUND
  ADJUSTMENT

  @@map("transaction_type_value")
}

model AppUser {
  id        String   @id @db.Uuid
  email     String?  @unique
  fullName  String?  @map("full_name")
  role      String   @default("manager")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("app_users")
}

model Model {
  id           BigInt        @id @default(autoincrement()) @db.BigInt
  userId       String        @map("user_id") @db.Uuid
  name         String
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  sizes        Size[]
  colors       Color[]
  inventory    Inventory[]
  factoryArrivalItems FactoryArrivalItem[]
  transactions Transaction[]

  @@unique([id, userId])
  @@unique([userId, name])
  @@index([userId, createdAt(sort: Desc)], map: "models_user_id_created_at_idx")
  @@map("models")
}

model Size {
  id           BigInt        @id @default(autoincrement()) @db.BigInt
  userId       String        @map("user_id") @db.Uuid
  modelId      BigInt        @map("model_id") @db.BigInt
  name         String
  sortOrder    Int           @default(0) @map("sort_order")
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  model        Model         @relation(fields: [modelId, userId], references: [id, userId], onDelete: Cascade)
  inventory    Inventory[]
  transactions Transaction[]

  @@unique([modelId, id, userId])
  @@unique([userId, modelId, name])
  @@index([modelId, userId], map: "sizes_model_id_user_id_idx")
  @@index([userId, sortOrder, modelId, name], map: "sizes_user_id_sort_order_model_id_name_idx")
  @@map("sizes")
}

model Color {
  id           BigInt        @id @default(autoincrement()) @db.BigInt
  userId       String        @map("user_id") @db.Uuid
  modelId      BigInt        @map("model_id") @db.BigInt
  name         String
  rgbCode      String        @map("rgb_code")
  textWhite    Boolean       @default(false) @map("text_white")
  sortOrder    Int           @default(0) @map("sort_order")
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  model        Model         @relation(fields: [modelId, userId], references: [id, userId], onDelete: Cascade)
  inventory    Inventory[]
  transactions Transaction[]

  @@unique([modelId, id, userId])
  @@unique([userId, modelId, name])
  @@index([modelId, userId], map: "colors_model_id_user_id_idx")
  @@index([userId, sortOrder, modelId, name], map: "colors_user_id_sort_order_model_id_name_idx")
  @@map("colors")
}

model Warehouse {
  id        BigInt        @id @default(autoincrement()) @db.BigInt
  userId    String        @map("user_id") @db.Uuid
  name      String
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  inventory Inventory[]
  Transaction Transaction[]

  @@unique([id, userId])
  @@unique([userId, name])
  @@index([userId, createdAt(sort: Desc)], map: "warehouses_user_id_created_at_idx")
  @@map("warehouses")
}

model Factory {
  id        BigInt           @id @default(autoincrement()) @db.BigInt
  userId    String           @map("user_id") @db.Uuid
  name      String
  contactName String?        @map("contact_name")
  phone     String?
  email     String?
  notes     String?
  isActive  Boolean          @default(true) @map("is_active")
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime         @default(now()) @map("updated_at") @db.Timestamptz(6)
  arrivals  FactoryArrival[]

  @@unique([id, userId])
  @@unique([userId, name])
  @@index([userId, createdAt(sort: Desc)], map: "factories_user_id_created_at_idx")
  @@map("factories")
}

model FactoryArrival {
  id           BigInt               @id @default(autoincrement()) @db.BigInt
  userId       String               @map("user_id") @db.Uuid
  factoryId    BigInt               @map("factory_id") @db.BigInt
  referenceCode String?             @map("reference_code")
  expectedDate DateTime             @map("expected_date") @db.Date
  status       String
  sourceChannel String              @map("source_channel")
  memo         String?
  createdAt    DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime             @default(now()) @map("updated_at") @db.Timestamptz(6)
  factory      Factory              @relation(fields: [factoryId, userId], references: [id, userId], onDelete: Cascade)
  items        FactoryArrivalItem[]

  @@unique([id, userId])
  @@index([userId, expectedDate(sort: Asc), createdAt(sort: Desc)], map: "factory_arrivals_user_expected_date_idx")
  @@index([factoryId, userId], map: "factory_arrivals_factory_id_user_id_idx")
  @@map("factory_arrivals")
}

model FactoryArrivalItem {
  id               BigInt         @id @default(autoincrement()) @db.BigInt
  userId           String         @map("user_id") @db.Uuid
  factoryArrivalId BigInt         @map("factory_arrival_id") @db.BigInt
  modelId          BigInt         @map("model_id") @db.BigInt
  sizeId           BigInt         @map("size_id") @db.BigInt
  colorId          BigInt         @map("color_id") @db.BigInt
  orderedQuantity  Int            @map("ordered_quantity")
  receivedQuantity Int            @default(0) @map("received_quantity")
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)
  arrival          FactoryArrival @relation(fields: [factoryArrivalId, userId], references: [id, userId], onDelete: Cascade)
  model            Model          @relation(fields: [modelId, userId], references: [id, userId], onDelete: Cascade)
  size             Size           @relation(fields: [modelId, sizeId, userId], references: [modelId, id, userId], onDelete: Cascade)
  color            Color          @relation(fields: [modelId, colorId, userId], references: [modelId, id, userId], onDelete: Cascade)

  @@index([factoryArrivalId, userId], map: "factory_arrival_items_arrival_id_user_id_idx")
  @@index([modelId, userId], map: "factory_arrival_items_model_id_user_id_idx")
  @@map("factory_arrival_items")
}

model Inventory {
  id        BigInt         @id @default(autoincrement()) @db.BigInt
  userId    String         @map("user_id") @db.Uuid
  modelId   BigInt         @map("model_id") @db.BigInt
  sizeId    BigInt         @map("size_id") @db.BigInt
  colorId   BigInt         @map("color_id") @db.BigInt
  warehouseId BigInt       @map("warehouse_id") @db.BigInt
  quantity  Int            @default(0)
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)
  model     Model          @relation(fields: [modelId, userId], references: [id, userId], onDelete: Cascade)
  size      Size           @relation(fields: [modelId, sizeId, userId], references: [modelId, id, userId], onDelete: Cascade)
  color     Color          @relation(fields: [modelId, colorId, userId], references: [modelId, id, userId], onDelete: Cascade)
  warehouse Warehouse      @relation(fields: [warehouseId, userId], references: [id, userId], onDelete: Cascade)

  @@unique([userId, modelId, sizeId, colorId, warehouseId])
  @@index([modelId, userId], map: "inventory_model_id_user_id_idx")
  @@index([modelId, sizeId, userId], map: "inventory_model_id_size_id_user_id_idx")
  @@index([modelId, colorId, userId], map: "inventory_model_id_color_id_user_id_idx")
  @@map("inventory")
}

model Transaction {
  id        BigInt               @id @default(autoincrement()) @db.BigInt
  userId    String               @map("user_id") @db.Uuid
  date      DateTime             @db.Date
  modelId   BigInt               @map("model_id") @db.BigInt
  sizeId    BigInt               @map("size_id") @db.BigInt
  colorId   BigInt               @map("color_id") @db.BigInt
  type      TransactionTypeValue
  quantity  Int
  warehouseId BigInt             @map("warehouse_id") @db.BigInt
  sourceChannel String?          @map("source_channel")
  referenceType String?          @map("reference_type")
  referenceId BigInt?            @map("reference_id") @db.BigInt
  memo      String?
  createdAt DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  model     Model                @relation(fields: [modelId, userId], references: [id, userId], onDelete: Cascade)
  size      Size                 @relation(fields: [modelId, sizeId, userId], references: [modelId, id, userId], onDelete: Cascade)
  color     Color                @relation(fields: [modelId, colorId, userId], references: [modelId, id, userId], onDelete: Cascade)
  warehouse Warehouse            @relation(fields: [warehouseId, userId], references: [id, userId], onDelete: Cascade)

  @@index([userId, date(sort: Desc), createdAt(sort: Desc)], map: "transactions_user_date_created_at_idx")
  @@index([modelId, userId], map: "transactions_model_id_user_id_idx")
  @@index([modelId, sizeId, userId], map: "transactions_model_id_size_id_user_id_idx")
  @@index([modelId, colorId, userId], map: "transactions_model_id_color_id_user_id_idx")
  @@map("transactions")
}

model ShippingProviderCredential {
  id               BigInt   @id @default(autoincrement()) @db.BigInt
  userId           String   @map("user_id") @db.Uuid
  provider         String
  encryptedPayload String   @map("encrypted_payload")
  iv               String
  authTag          String   @map("auth_tag")
  keyVersion       Int      @default(1) @map("key_version") @db.SmallInt
  maskedSummary    Json     @default("{}") @map("masked_summary")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([userId, provider])
  @@map("shipping_provider_credentials")
}
